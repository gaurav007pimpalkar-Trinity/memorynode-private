# MemoryNode API — optional and production variables (Mode 3)
#
# Copy selected keys into `apps/api/.dev.vars` or set via `wrangler secret put`.
# You do not need most of these for a first local run — see `.env.local.example`.
#
# --- Real embeddings + extraction (costs real API usage) ---
# OPENAI_API_KEY=
# EMBEDDINGS_MODE=openai
#
# --- Global AI spend ceiling (INR, optional kill switch) ---
# AI_COST_BUDGET_INR=
# USD_TO_INR=83
# COST_DRIFT_MULTIPLIER=1.35
#
# --- Billing (only if you exercise checkout webhooks locally) ---
# PAYU_MERCHANT_KEY=
# PAYU_MERCHANT_SALT=
# PAYU_WEBHOOK_SECRET=
# PAYU_BASE_URL=
# PAYU_VERIFY_URL=
#
# --- Rate limits & access posture ---
# RATE_LIMIT_MODE=on
# SUPABASE_ACCESS_MODE=rpc-first
# REQUEST_SCOPED_DB_ENABLED=0
#
# --- Dashboard / CORS ---
# PUBLIC_APP_URL=http://localhost:5173
#
# See `apps/api/.dev.vars.template` for the complete annotated template.
