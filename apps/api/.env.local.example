# Minimal local API (copy to apps/api/.dev.vars — Wrangler reads .dev.vars, not this file name)
# See docs/self-host/LOCAL_DEV.md

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
OPENAI_API_KEY=
API_KEY_SALT=
MASTER_ADMIN_TOKEN=
SUPABASE_MODE=dev
SUPABASE_ACCESS_MODE=rpc-first
EMBEDDINGS_MODE=stub
ENVIRONMENT=dev
RATE_LIMIT_MODE=on
PUBLIC_APP_URL=http://localhost:5173
