{
  "name": "@memorynode/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec wrangler dev",
    "lint": "eslint src tests",
    "typecheck": "tsc -b",
    "test": "vitest run --root ../.. apps/api/tests",
    "diagnose:workspace": "node scripts/diagnose_workspace_insert.mjs",
    "build": "pnpm exec wrangler deploy --env staging --dry-run",
    "deploy:staging": "pnpm exec wrangler deploy --env staging",
    "deploy:production": "pnpm exec wrangler deploy --env production",
    "deploy:prod": "node scripts/deploy_prod_with_version.mjs"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@memorynodeai/mcp-core": "workspace:^",
    "@memorynodeai/shared": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.45.2",
    "jszip": "^3.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "yaml": "^2.7.0"
  }
}
