{
  "name": "memorynode-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @memorynode/api dev",
    "dev:stub": "node scripts/dev_stub.mjs",
    "preflight:dev": "node scripts/preflight_dev_env.mjs",
    "mn": "node packages/cli/bin/mn.mjs",
    "dev:api": "node -e \"console.log('Base URL: http://127.0.0.1:' + (process.env.PORT || '8787'))\" && pnpm --filter @memorynode/api dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "check:workspace-scripts": "node scripts/check_workspace_scripts.mjs",
    "check:tracked-artifacts": "node scripts/check_tracked_runtime_artifacts.mjs",
    "check:wrangler": "node scripts/check_wrangler.mjs && node scripts/check_wrangler_prod.mjs",
    "prod:smoke": "node scripts/prod_smoke.mjs",
    "bootstrap:dev": "node scripts/dev_bootstrap.mjs",
    "smoke": "bash scripts/smoke.sh",
    "smoke:ps": "pwsh -ExecutionPolicy Bypass -File scripts/smoke.ps1",
    "smoke:ci": "SMOKE_MODE=ci bash scripts/smoke.sh",
    "load:smoke": "node scripts/load_smoke.mjs",
    "e2e:verify": "node scripts/e2e_verify.mjs",
    "test:ci": "pnpm run check:typed-entry && pnpm run check:wrangler && pnpm run migrations:check && pnpm run check:workspace-scope && pnpm run check:config && pnpm run check:api-surface-phase1 && pnpm run openapi:check && pnpm run check:docs-drift && pnpm --filter @memorynodeai/mcp-core run lint:noun-verb && vitest run --silent",
    "check:typed-entry": "node scripts/check_typed_entry.mjs",
    "check:workspace-scope": "node scripts/check_workspace_scope.mjs",
    "check:service-role-allowlist": "node scripts/check_service_role_allowlist.mjs",
    "check:request-path-least-privilege": "node scripts/check_request_path_least_privilege.mjs",
    "check:observability-contracts": "node scripts/check_observability_contracts.mjs",
    "check:runbooks": "node scripts/check_runbooks_contract.mjs",
    "check:dashboard-quality": "node scripts/check_dashboard_quality.mjs",
    "check:least-privilege": "node scripts/check_least_privilege_contract.mjs",
    "check:api-surface-phase1": "node scripts/check_api_surface_phase1.mjs",
    "check:config": "node scripts/check_config.mjs",
    "check:docs-billing": "node scripts/check_docs_billing.mjs",
    "check:economics-gate": "node scripts/check_economics_gate.mjs",
    "economics:workspaces": "node scripts/workspace_unit_economics.mjs",
    "ci:trust-gates": "node scripts/ci_trust_gates.mjs",
    "migrations:list": "node scripts/migrations_list.mjs",
    "migrations:check": "node scripts/migrations_check.mjs",
    "db:migrate": "node scripts/db_migrate.mjs",
    "db:migrate:verify": "node scripts/db_migrate_verify.mjs",
    "db:verify-rls": "node scripts/db_verify_rls.mjs",
    "db:verify-schema": "node scripts/db_verify_schema.mjs",
    "db:drift:test": "node scripts/db_migration_drift_test.mjs",
    "db:check": "pnpm migrations:check && pnpm db:migrate && pnpm db:verify-rls && pnpm db:verify-schema",
    "payu:smoke": "node scripts/payu_smoke.mjs",
    "payu:webhook-test": "node scripts/payu_webhook_test.mjs",
    "perf:k6": "k6 run scripts/perf_k6.js",
    "release:gate": "node scripts/release_gate_runner.mjs",
    "release:gate:full": "pnpm release:gate && pnpm db:check",
    "release:validate": "node scripts/post_deploy_validate.mjs",
    "release:staging:validate": "cross-env TARGET_ENV=staging node scripts/post_deploy_validate.mjs",
    "release:prod:validate": "cross-env TARGET_ENV=production node scripts/post_deploy_validate.mjs",
    "critical:flows:check": "node scripts/critical_flow_checks.mjs",
    "prod:check": "node scripts/prod_check.mjs",
    "deploy:staging": "cross-env CHECK_ENV=staging pnpm prod:check && node scripts/deploy_staging.mjs",
    "deploy:prod": "cross-env CHECK_ENV=production pnpm prod:check && node scripts/deploy_prod.mjs",
    "deploy": "pnpm deploy:prod",
    "prod:gate": "node scripts/prod_gate.mjs",
    "prod:gate:self-test": "node scripts/prod_gate_self_test.mjs",
    "smoke:staging": "node scripts/smoke_staging.mjs",
    "smoke:staging:dashboard": "node scripts/dashboard_staging_smoke.mjs",
    "smoke:workspace:bootstrap": "node scripts/bootstrap-smoke-workspace.mjs",
    "smoke:entitlement:check": "node scripts/check_smoke_entitlement.mjs",
    "staging:verify": "node scripts/verify_staging.mjs",
    "beta:verify": "node scripts/beta_verify.mjs",
    "smoke:prod": "node scripts/smoke_prod.mjs",
    "dashboard:build:prod-surfaces": "node scripts/dashboard_build_prod_surfaces.mjs",
    "dashboard:deploy:pages": "node scripts/deploy_dashboard_pages.mjs",
    "dashboard:verify:pages": "node scripts/verify_dashboard_pages_deploy.mjs",
    "staging:release-check": "node scripts/deploy_and_smoke_staging.mjs",
    "prod:release-check": "node scripts/deploy_and_smoke_prod.mjs",
    "prod:setup": "node scripts/print_prod_setup.mjs",
    "staging:setup": "node scripts/print_staging_setup.mjs",
    "secrets:check": "node scripts/secret_scan.mjs --staged",
    "secrets:check:tracked": "node scripts/secret_scan_tracked.mjs",
    "scan:secrets": "pnpm secrets:check:tracked",
    "openapi:gen": "node apps/api/scripts/generate_openapi.mjs",
    "openapi:check": "node apps/api/scripts/generate_openapi.mjs --check",
    "check:docs-drift": "node scripts/check_docs_drift.mjs",
    "sync:public-github": "node scripts/sync_public_github_repo.mjs",
    "sync:public-github:commit": "node scripts/sync_public_github_repo.mjs --commit",
    "sync:public-github:push": "node scripts/sync_public_github_repo.mjs --push",
    "push:gate": "pnpm secrets:check && pnpm secrets:check:tracked && pnpm lint && pnpm typecheck && pnpm test:ci"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260205.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "5.5.4",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18",
    "wrangler": "^4.63.0",
    "pg": "^8.11.5",
    "cross-env": "^7.0.3"
  }
}
