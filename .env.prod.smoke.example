## Copy to .env.prod.smoke and fill before prod release check; DO NOT commit.
DEPLOY_ENV=production                      # deploy: production environment marker (set by script if missing)
BASE_URL=https://api.example.com          # smoke/deploy: public prod Worker URL (https://)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require  # db:migrate: prod Postgres URL (SSL required)
SUPABASE_URL=https://your-project.supabase.co  # deploy: Supabase REST URL (Project Settings -> API)
API_KEY_SALT=prod_salt                    # deploy/API: salt used for API key hashing (matches app_settings.api_key_salt)
MASTER_ADMIN_TOKEN=prod_admin_token       # deploy/API: admin header x-admin-token
EMBEDDINGS_MODE=openai                    # deploy/API: "openai" expected in prod
OPENAI_API_KEY=OPENAI_API_KEY_PLACEHOLDER # deploy/API: required when EMBEDDINGS_MODE=openai
MEMORYNODE_API_KEY=MEMORYNODE_API_KEY_PLACEHOLDER # smoke: prod API key for data-plane calls
RATE_LIMIT_DO=prod-do-binding             # deploy: Durable Object binding name (matches wrangler.toml)
BUILD_VERSION=                            # optional: version stamp to serve via /healthz
STRIPE_SECRET_KEY=                        # prod Stripe secret (live)
STRIPE_WEBHOOK_SECRET=                    # prod Stripe webhook signing secret (live)
CLOUDFLARE_API_TOKEN=                     # optional: if using token for wrangler auth instead of login
DEPLOY_CONFIRM=memorynode-prod            # required safety latch for prod deploy
DRY_RUN=1                                 # set to 1 for dry-run; unset/empty for real deploy
