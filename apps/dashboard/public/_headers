# Phase 0 G5: Security headers for dashboard (Cloudflare Pages).
# CSP: no unsafe-inline for scripts; style-src allows 'unsafe-inline' for inline styles in index.html (documented exception).
# connect-src allows same origin + Supabase + any HTTPS (API base URL varies by env).
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https: wss:; img-src 'self' data: https:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=()
