## Copy to .env.staging.smoke and fill before `pnpm staging:release-check`
## Do NOT commit .env.staging.smoke.
# DEPLOY_ENV example: staging
DEPLOY_ENV=
# BASE_URL format: https://api-staging.example.com
BASE_URL=
# DATABASE_URL format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=
# SUPABASE_URL format: https://your-project.supabase.co
SUPABASE_URL=
# API_KEY_SALT placeholder: STAGING_API_KEY_SALT_PLACEHOLDER
API_KEY_SALT=
# MASTER_ADMIN_TOKEN placeholder: STAGING_MASTER_ADMIN_TOKEN_PLACEHOLDER
MASTER_ADMIN_TOKEN=
# EMBEDDINGS_MODE values: openai | stub
EMBEDDINGS_MODE=
# OPENAI_API_KEY placeholder: OPENAI_API_KEY_PLACEHOLDER
OPENAI_API_KEY=
# MEMORYNODE_API_KEY placeholder: MEMORYNODE_API_KEY_PLACEHOLDER
MEMORYNODE_API_KEY=
# RATE_LIMIT_DO placeholder: staging-do-binding
RATE_LIMIT_DO=
# BUILD_VERSION placeholder: 2026.02.10-abcdef0
BUILD_VERSION=
# PAYU_MERCHANT_KEY placeholder: PAYU_MERCHANT_KEY_PLACEHOLDER
PAYU_MERCHANT_KEY=
# PAYU_MERCHANT_SALT placeholder: PAYU_MERCHANT_SALT_PLACEHOLDER
PAYU_MERCHANT_SALT=
# PAYU_WEBHOOK_SECRET placeholder: PAYU_WEBHOOK_SECRET_PLACEHOLDER
PAYU_WEBHOOK_SECRET=
# PAYU_BASE_URL example: https://secure.payu.in
PAYU_BASE_URL=
# PAYU_VERIFY_URL example: https://info.payu.in/merchant/postservice?form=2
PAYU_VERIFY_URL=
# PAYU_CURRENCY example: INR
PAYU_CURRENCY=
# CLOUDFLARE_API_TOKEN placeholder: CLOUDFLARE_API_TOKEN_PLACEHOLDER
CLOUDFLARE_API_TOKEN=
# DRY_RUN value example: 1
DRY_RUN=
