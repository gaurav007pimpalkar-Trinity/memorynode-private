# Secrets (store locally for dev; set with `wrangler secret put NAME` in prod)
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
API_KEY_SALT=
MASTER_ADMIN_TOKEN=
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_WEBHOOK_SECRET=

# Vars (safe to keep in wrangler.toml)
SUPABASE_URL=
SUPABASE_MODE=dev
EMBEDDINGS_MODE=stub # dev-only; set to openai in prod
ENVIRONMENT=dev
RATE_LIMIT_MODE=on
PUBLIC_APP_URL=http://localhost:5173
PAYU_BASE_URL=https://secure.payu.in/_payment
PAYU_VERIFY_URL=https://info.payu.in/merchant/postservice?form=2
PAYU_CURRENCY=INR
# Per-plan amounts (optional; fallback PAYU_PRO_AMOUNT). Values as string, e.g. 299.00
# PAYU_LAUNCH_AMOUNT=299.00
# PAYU_BUILD_AMOUNT=499.00
# PAYU_DEPLOY_AMOUNT=1999.00
# PAYU_SCALE_AMOUNT=4999.00
PAYU_PRO_AMOUNT=499.00
PAYU_PRODUCT_INFO=MemoryNode Platform
PAYU_SUCCESS_PATH=/settings/billing?status=success
PAYU_CANCEL_PATH=/settings/billing?status=canceled
