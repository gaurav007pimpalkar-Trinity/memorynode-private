# Copy to .env.production (gitignored) for local `pnpm build` of the dashboard, or set the same vars in CI.
# Use your deployed API origin (not localhost) so Vite production builds pass the API base guard.

VITE_API_BASE_URL=https://api.memorynode.ai
VITE_APP_SURFACE=console
VITE_CONSOLE_BASE_URL=https://console.memorynode.ai
# Commit baked into dist/version.json (CI sets automatically; locally use: git rev-parse HEAD)
# VITE_BUILD_SHA=
