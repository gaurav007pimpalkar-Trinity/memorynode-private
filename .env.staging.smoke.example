## Copy to .env.staging.smoke and fill before `pnpm staging:release-check`
## Do NOT commit .env.staging.smoke.
DEPLOY_ENV=staging                     # deploy: staging environment marker (set by script if missing)
BASE_URL=https://api-staging.example.com   # smoke/deploy: public Worker URL (must include https://)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require   # db:migrate: Supabase/Postgres URL (pooler or direct), require SSL
SUPABASE_URL=https://your-project.supabase.co   # deploy: Supabase REST URL (Project Settings -> API)
API_KEY_SALT=staging_salt              # deploy/API: salt used for API key hashing (match app_settings.api_key_salt)
MASTER_ADMIN_TOKEN=staging_admin_token # deploy/API: admin header x-admin-token for control-plane endpoints
EMBEDDINGS_MODE=openai                 # deploy/API: "openai" or "stub" (staging should normally be openai)
OPENAI_API_KEY=OPENAI_API_KEY_PLACEHOLDER # deploy/API: required when EMBEDDINGS_MODE=openai
MEMORYNODE_API_KEY=MEMORYNODE_API_KEY_PLACEHOLDER # smoke: staging API key for data-plane calls
RATE_LIMIT_DO=staging-do-binding       # deploy: Durable Object binding name (matches wrangler.toml)
BUILD_VERSION=                         # optional: version stamp to serve via /healthz
STRIPE_SECRET_KEY=                     # optional: staging Stripe secret (if billing exercised)
STRIPE_WEBHOOK_SECRET=                 # optional: staging Stripe webhook signing secret
CLOUDFLARE_API_TOKEN=                  # optional: if using API token for wrangler auth instead of login
DRY_RUN=1                              # set to 1 for dry-run; unset/empty for real deploy
